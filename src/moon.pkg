import {
  "bikallem/webapi",
  "moonbitlang/core/cmp",
  "moonbitlang/core/hashmap",
  "moonbitlang/core/hashset",
}

supported_targets = "js+wasm-gc"

options(
  exclude: [ "examples", "tests" ],
  link: {
    "wasm-gc": {
      "imported-string-constants": "_",
      "use-js-builtin-string": true,
    },
  },
)
